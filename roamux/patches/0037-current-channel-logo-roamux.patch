@@ -33,7 +34,11 @@ int CurrentChannelLogoResourceId() {
       [[fallthrough]];
 #endif
     case version_info::Channel::UNKNOWN:
-      return IDR_PRODUCT_LOGO_32;
+      // Roamux (roam-158): every current-channel-logo surface (settings
